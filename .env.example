# turbo3 CUDA — Environment Configuration
#
# Copy this to .env and adjust for your setup:
#   cp .env.example .env

# Path to your GGUF model
TURBO_MODEL_PATH=./models/your-model.gguf

# Context window size (tokens)
# turbo3 K+V: ~14KB per token, so 524K ≈ 7.2GB KV cache
TURBO_CONTEXT=524288

# Server port
TURBO_PORT=8080

# GPU layers to offload (99 = all)
TURBO_GPU_LAYERS=99

# CUDA device (uncomment to select specific GPU)
# CUDA_VISIBLE_DEVICES=0
